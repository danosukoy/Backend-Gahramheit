                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "1",
                                "role"
                            ],
                            "query": [
                                {
                                    "key": "role",
                                    "value": "ADMIN"
                                }
                            ]
                        }
                    },
                    "response": []
